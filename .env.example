# ============================================================================
#  VIN Delivery Tracker — environment configuration
# ============================================================================
#  Copy this file to `.env.local` and fill in your Metabase details.
#  Leave DATA_SOURCE=mock to run fully on synthetic data (no DB needed).
# ============================================================================

# ---- Data source ------------------------------------------------------------
# "mock"     -> synthetic data, no DB needed (default, great for a first look)
# "metabase" -> call the combined saved question (card) on real data
DATA_SOURCE=mock

# ---- Metabase connection ----------------------------------------------------
# Base URL of your Metabase instance (no trailing slash)
METABASE_URL=https://metabase.spyne.ai

# --- Choose ONE way for the app to read the combined question ---
# Option 1 (no API key): enable public sharing on the combined question and put
# its public UUID here. The app calls /api/public/card/:uuid/query. Takes priority.
METABASE_PUBLIC_UUID=
# Option 2: the numeric id of the combined question + an API key/login below.
METABASE_CARD_ID=

# --- Auth (only needed for Option 2 / METABASE_CARD_ID) ---
# Method A (recommended, Metabase >= 0.49): an API key (Admin -> Settings -> API Keys)
METABASE_API_KEY=
# Method B: username + password (a session token is fetched automatically)
METABASE_USERNAME=
METABASE_PASSWORD=

# NOTE: the combined question self-filters to the rolling last 30 days, so no
# date parameters are sent. The dashboard's date pickers narrow within that
# window client-side.

# ---- Business config --------------------------------------------------------
# End-to-end TAT target in HOURS. Deliverables finished within this are on-SLA.
TAT_TARGET_HOURS=24

# Stage aging thresholds in HOURS (tech,ai,qc). In-progress beyond this = aging.
STAGE_AGING_THRESHOLDS_HOURS=8,8,4
